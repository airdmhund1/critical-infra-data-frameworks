<?xml version="1.0" encoding="UTF-8"?>
<!--
  OWASP Dependency-Check suppression file.

  Use this file to suppress false-positive CVE findings after engineering review.
  Each suppression must include:
    - The CVE identifier being suppressed
    - A comment explaining why it is a false positive or accepted risk
    - The date the suppression was added and who approved it

  IMPORTANT: Suppressions are not permanent waivers.  Review suppressed CVEs
  at each quarterly security review and remove entries for patched versions.

  Format reference:
  https://jeremylong.github.io/DependencyCheck/general/suppression.html

  Example (do not uncomment without a genuine false-positive justification):

  <suppress>
    <notes>
      CVE-2021-XXXXX: False positive — this CVE affects the server-side component
      only.  Our dependency uses the client-side library which is not affected.
      Reviewed: 2026-04-22, approved by: security-review@criticalinfra.com
    </notes>
    <cve>CVE-2021-XXXXX</cve>
  </suppress>
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
  <!-- No suppressions at this time.  All HIGH/CRITICAL CVEs must be remediated. -->
</suppressions>
