# ============================================================
# Critical Infrastructure Data Frameworks — local dev .env example
# ============================================================
# Copy this file to `.env` (NOT committed) and fill in values for
# your local docker-compose stack. Never put production credentials
# in either this file or the `.env` you create.
#
#   cp deployment/docker/.env.example deployment/docker/.env
#   # then edit deployment/docker/.env
#
# The `replace-me` strings below are intentional placeholders — they
# will fail loudly if a developer forgets to override them, which is
# exactly what we want for a credentials template.

# Postgres (test source)
POSTGRES_USER=replace-me
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=cidf_dev

# MinIO (S3-compatible Bronze storage)
MINIO_ROOT_USER=replace-me
MINIO_ROOT_PASSWORD=replace-me-min-8-chars

# Vault (dev mode)
VAULT_DEV_ROOT_TOKEN=replace-me-dev-only-token
